---
interface Props {
    current?: string;
}

const { current } = Astro.props;

let base = import.meta.env.BASE_URL;

if (!base.endsWith('/')) {
    base += '/';
}

const links = [
    { href: `${base}`, label: "Home", id: "home" },
    { href: `${base}about`, label: "About", id: "about" },
    { href: `${base}facts`, label: "Facts", id: "facts" },
    { href: `${base}contact`, label: "Contact", id: "contact" },
    { href: `${base}equipment`, label: "Equipment", id: "equipment" },
];
---

<nav>
    <ul>
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class={link.id === current ? "selected" : ""}
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
<style>
    header {
        padding: 5px 0;
        margin: 10px auto;
    }

    @media (prefers-contrast: more) {
        header {
            color: #fff;
        }
    }

    header h1 {
        font-size: 40px;
        margin: 0;
    }

    nav a {
        color: white;
        font-weight: normal;
    }

    nav a.selected {
        font-weight: bold;
        text-decoration: none;
    }

    nav a:hover {
        text-decoration: none;
    }

    nav ul {
        margin-left: -20px;
        margin-right: 10px;
    }
</style>
