---
interface Props {
    current?: string;
}

let { current } = Astro.props;
if (!current) {
    current = "home";
}

let base = import.meta.env.BASE_URL;

if (!base.endsWith('/')) {
    base += '/';
}

const links = [
    { href: `${base}`, label: "Home", id: "home" },
    { href: `${base}about`, label: "About", id: "about" },
    { href: `${base}facts`, label: "Facts", id: "facts" },
    { href: `${base}contact`, label: "Contact", id: "contact" },
    { href: `${base}equipment`, label: "Equipment", id: "equipment" },
];
---

<header>
    <h1>kier(.)ov(h)nik{(current != "home" && (<span>/{current}</span>))}</h1>
</header>
<nav>
    <ul>
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class={link.id.startsWith(current) ? "selected" : ""}
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
<style>
    header {
        font-family: 'Courier New', Courier, monospace;
        padding: 5px 0;
        margin: 10px auto;
        width: 90vw;
    }

    @media (prefers-contrast: more) {
        header {
            color: #fff;
        }
    }

    header h1 {
        font-size: 24px;
        margin: 0;
    }

    nav ul {
        font-family: 'Courier New', Courier, monospace;
        width: 90vw;
        list-style-type: none;
        margin: 0 auto;
        padding: 0;
        overflow: hidden;
        color: #e8def8;
    }

    nav li {
        float: left;
    }

    nav a {
        color: white;
        text-decoration: none;
        padding-right: 10px;
        font-weight: normal;
    }

    nav a:hover {
        text-decoration: underline;
    }
</style>
