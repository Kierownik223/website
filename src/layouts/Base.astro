---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title, current, frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title ? title : frontmatter.title } />
	</head>
	<body>
		<header>
			<h1>Kierownik223's website</h1>
		</header>
		<table width="100%" height="100%" cellpadding="0" cellspacing="0">
			<tr>
				<td valign="top">
					<Header current={current ? current : frontmatter.current } />
				</td>

				<td valign="top">
					</aside>
					<div class="main">
						<slot />
					</div>
					<Footer />
				</td>
			</tr>
		</table>
</html>
